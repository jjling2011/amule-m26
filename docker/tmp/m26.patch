+void m26_typeof_node(PHP_VALUE_NODE *result)
+{
+	value_value_free(result);
+	result->type = PHP_VAL_STRING;
+
+	PHP_SCOPE_ITEM *si = get_scope_item(g_current_scope, "__param_0");
+	if ( !si ) {
+		result->str_val = strdup("null");
+		return;
+	}
+
+	switch(si->type) {
+		case PHP_SCOPE_NONE: result->str_val = strdup("none"); return;
+		case PHP_SCOPE_FUNC: result->str_val = strdup("func"); return;
+		case PHP_SCOPE_CLASS: result->str_val = strdup("class"); return;
+
+		// everything is param!
+		// case PHP_SCOPE_PARAM: result->str_val = strdup("param"); return;
+
+		default: break;
+	}
+
+	PHP_VALUE_NODE *array = &(si->var->value);
+	switch(array->type) {
+		case PHP_VAL_BOOL: result->str_val = strdup("bool"); return;
+		case PHP_VAL_INT: result->str_val = strdup("int"); return;
+		case PHP_VAL_FLOAT: result->str_val = strdup("float"); return;
+		case PHP_VAL_STRING: result->str_val = strdup("string"); return;
+		case PHP_VAL_OBJECT: {
+			const char *name = si->var->value.obj_val.class_name;
+
+			// strlen("object()") == 8
+			int total_size = 8 + strlen(name) + 1;
+			result->str_val = (char *)malloc(total_size);
+
+			snprintf(result->str_val, total_size, "object(%s)", name);
+			return;
+		}
+		case PHP_VAL_ARRAY: {
+			PHP_ARRAY_TYPE *arr_ptr = (PHP_ARRAY_TYPE *)array->ptr_val;
+			if(array_get_size(array) < 1 || arr_ptr->array.count("0") > 0) {
+				result->str_val = strdup("array");
+			} else {
+				result->str_val = strdup("map");
+			}
+			return;
+		}
+		case PHP_VAL_NONE: result->str_val = strdup("none"); return;
+		case PHP_VAL_VAR_NODE: result->str_val = strdup("ref"); return;
+		default: result->str_val = strdup("private"); return;
+	}
+}
