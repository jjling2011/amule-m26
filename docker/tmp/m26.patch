+void m26_get_version(PHP_VALUE_NODE *val)
+{
+	if ( !val ) {
+		return;
+	}
+	value_value_free(val);
+
+	val->type = PHP_VAL_STRING;
+	val->str_val = strdup("amule-m26 v0.1.0");
+}
+
+// PHP_VAL_INT m26_hash_string(PHP_VAL_STRING string, PHP_VAL_INT oldHash)
+void m26_hash_string(PHP_VALUE_NODE *result)
+{
+	value_value_free(result);
+	result->type = PHP_VAL_INT;
+
+	PHP_SCOPE_ITEM *si = get_scope_item(g_current_scope, "__param_0");
+	if ( !si || (si->var->value.type != PHP_VAL_STRING)) {
+		php_report_error(PHP_ERROR, "Invalid or missing argument 1 (string)");
+		return;
+	}
+	char *str = si->var->value.str_val;
+
+	constexpr uint64_t FNV_OFFSET_BASIS_64 = 14695981039346656037ULL;
+	constexpr uint64_t FNV_PRIME_64 = 1099511628211ULL;
+
+	uint64_t hash = FNV_OFFSET_BASIS_64;
+	si = get_scope_item(g_current_scope, "__param_1");
+	if ( si && (si->var->value.type == PHP_VAL_INT)
+		&& (si->var->value.int_val != 0)
+	) {
+		hash = si->var->value.int_val;
+	}
+
+	if (str != NULL) {
+		while (*str) {
+			hash ^= (uint64_t)(unsigned char)(*str);
+			hash *= FNV_PRIME_64;
+			str++;
+		}
+    }
+	result->int_val = hash;
+}
+
+// bool startswith(string needle, string haystack)
+void m26_startswith(PHP_VALUE_NODE *result)
+{
+	value_value_free(result);
+	result->type = PHP_VAL_BOOL;
+
+	PHP_SCOPE_ITEM *si = get_scope_item(g_current_scope, "__param_0");
+	if ( !si || (si->var->value.type != PHP_VAL_STRING)) {
+		php_report_error(PHP_ERROR, "Invalid or missing argument 1 (needle)");
+		return;
+	}
+	char *needle = si->var->value.str_val;
+
+	si = get_scope_item(g_current_scope, "__param_1");
+	if ( !si || (si->var->value.type != PHP_VAL_STRING)) {
+		php_report_error(PHP_ERROR, "Invalid or missing argument 2 (haystack)");
+		return;
+	}
+	char *haystack = si->var->value.str_val;
+
+	if (needle == NULL || *needle == '\0') {
+		result->int_val = 1;
+	}else if (haystack == NULL || *haystack == '\0') {
+		result->int_val = 0;
+	}else {
+		size_t needle_len = strlen(needle);
+		size_t haystack_len = strlen(haystack);
+		if (needle_len > haystack_len) {
+			result->int_val = 0;
+		} else {
+			result->int_val = strncmp(haystack, needle, needle_len) == 0 ? 1 : 0;
+		}
+	}
+}
+
+// bool endswith(string needle, string haystack)
+void m26_endswith(PHP_VALUE_NODE *result)
+{
+	value_value_free(result);
+	result->type = PHP_VAL_BOOL;
+
+	PHP_SCOPE_ITEM *si = get_scope_item(g_current_scope, "__param_0");
+	if ( !si || (si->var->value.type != PHP_VAL_STRING)) {
+		php_report_error(PHP_ERROR, "Invalid or missing argument 1 (needle)");
+		return;
+	}
+	char *needle = si->var->value.str_val;
+
+	si = get_scope_item(g_current_scope, "__param_1");
+	if ( !si || (si->var->value.type != PHP_VAL_STRING)) {
+		php_report_error(PHP_ERROR, "Invalid or missing argument 2 (haystack)");
+		return;
+	}
+	char *haystack = si->var->value.str_val;
+
+	if (needle == NULL || *needle == '\0') {
+		result->int_val = 1;
+		return;
+	}
+
+	if (haystack == NULL || *haystack == '\0') {
+		result->int_val = 0;
+		return;
+	}
+
+	size_t needle_len = strlen(needle);
+	size_t haystack_len = strlen(haystack);
+	if (needle_len > haystack_len) {
+		result->int_val = 0;
+		return;
+	}
+
+	const char *haystack_end = haystack + (haystack_len - needle_len);
+	result->int_val = strcmp(haystack_end, needle) == 0 ? 1 : 0;
+}
